{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "./hooks/guard-shell.sh",
        "matcher": "git |gh |pnpm ",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "rtk hook cursor",
        "matcher": "Shell"
      }
    ]
  }
}
