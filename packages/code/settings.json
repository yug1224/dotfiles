{
  "[css]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[html]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[jsonc]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[markdown]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[terraform-vars]": {
    "editor.codeActionsOnSave": {
      "source.formatAll.terraform": "explicit"
    },
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": false
  },
  "[terraform]": {
    "editor.codeActionsOnSave": {
      "source.formatAll.terraform": "explicit"
    },
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[vue]": {
    "editor.codeActionsOnSave": {
      "source.format.oxc": "never"
    },
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "better-comments.tags": [
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#98C379",
      "italic": false,
      "strikethrough": false,
      "tag": "*",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#3498DB",
      "italic": false,
      "strikethrough": false,
      "tag": "?",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF2D00",
      "italic": false,
      "strikethrough": false,
      "tag": "!",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#474747",
      "italic": false,
      "strikethrough": true,
      "tag": "//",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF8C00",
      "italic": false,
      "strikethrough": false,
      "tag": "todo",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF8C00",
      "italic": false,
      "strikethrough": false,
      "tag": "bug",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF8C00",
      "italic": false,
      "strikethrough": false,
      "tag": "fixme",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF2D00",
      "italic": false,
      "strikethrough": false,
      "tag": "hack",
      "underline": false
    },
    {
      "backgroundColor": "transparent",
      "bold": false,
      "color": "#FF2D00",
      "italic": false,
      "strikethrough": false,
      "tag": "xxx",
      "underline": false
    }
  ],
  "cSpell.userWords": [
    "abortable",
    "astro",
    "astrojs",
    "codegen",
    "connpass",
    "contentful",
    "csstype",
    "deno",
    "denoland",
    "dontshownewversionmessage",
    "dotfiles",
    "esbenp",
    "githubactions",
    "hrbrain",
    "lefthook",
    "liveshare",
    "menlo",
    "plemoljp",
    "polacode",
    "qiita",
    "tsconfigs",
    "unplugin",
    "vetur",
    "vsicons",
    "Yamaguchi",
    "Yuji",
    "Zenn"
  ],
  "customLocalFormatters.formatters": [
    {
      "command": "__DOTFILES__/packages/code/bin/oxfmt-stdin.sh f.css",
      "languages": ["css"]
    },
    {
      "command": "__DOTFILES__/packages/code/bin/oxfmt-stdin.sh f.html",
      "languages": ["html"]
    },
    {
      "command": "__DOTFILES__/packages/code/bin/oxfmt-stdin.sh f.json",
      "languages": ["json", "jsonc"]
    },
    {
      "command": "__DOTFILES__/packages/code/bin/oxfmt-stdin.sh f.md",
      "languages": ["markdown"]
    },
    {
      "command": "__DOTFILES__/packages/code/bin/oxfmt-stdin.sh f.vue",
      "languages": ["vue"]
    }
  ],
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.disabledLanguages": ["scminput"],
  "cursor.enable_agent_window_setting": false,
  "datadog.connection.oauth.setup.domain": "ap1.datadoghq.com",
  "datadog.cursor.notification.suppressMcpMigrationMessage": true,
  "diffEditor.codeLens": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.maxComputationTime": 0,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.format.oxc": "always"
  },
  "editor.fontFamily": "PlemolJP Console, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.inlineSuggest.enabled": true,
  "editor.largeFileOptimizations": false,
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "all",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.allowedCharacters": {
    "〇": true
  },
  "editor.unicodeHighlight.nonBasicASCII": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.cts": "${capture}.typegen.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.mts": "${capture}.typegen.ts",
    "*.ts": "${capture}.js, ${capture}.typegen.ts",
    "*.tsx": "${capture}.ts, ${capture}.typegen.ts",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "tsconfig.json": "tsconfig.*.json"
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git-worktree-manager.worktreePathTemplate": "$BASE_PATH-worktree",
  "git-worktree-manager.worktreeSubdirectoryTemplate": "worktree-$INDEX",
  "gitConfigUser.profiles": [
    {
      "email": "yuji.yamaguchi24@gmail.com",
      "label": "Yuji Yamaguchi",
      "selected": true,
      "userName": "Yuji Yamaguchi"
    }
  ],
  "go.toolsManagement.autoUpdate": true,
  "html.format.endWithNewline": true,
  "japanese-proofreading.maxNumberOfProblems": 500,
  "javascript.preferGoToSourceDefinition": false,
  "liveshare.presence": true,
  "makefile.configureOnOpen": false,
  "npm.keybindingsChangedWarningShown": true,
  "oxc.fmt.configPath": "__DOTFILES__/oxfmt.config.ts",
  "oxc.useExecPath": true,
  "reactSnippets.settings.typescript": false,
  // アノテーションコメントの一覧ツリー表示、ツリー表示させたいタグがあれば追加する
  "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "XXX"],
  "todo-tree.highlights.enabled": false,
  "typescript.preferGoToSourceDefinition": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.validate.enable": true,
  "vsicons.dontShowNewVersionMessage": true,
  "window.commandCenter": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "workbench.colorTheme": "Default Dark Modern",
  "claudeCode.preferredLocation": "sidebar",
  "window.autoDetectColorScheme": false
}
