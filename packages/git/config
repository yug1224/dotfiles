[user]
	signingkey = 1709BA423646DB4A
	useConfigOnly = true
[commit]
	gpgsign = true
[core]
	editor = vim
	precomposeunicode = true
	ignorecase = false
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
	side-by-side = true
	syntax-theme = Visual Studio Dark+
[merge]
	conflictstyle = diff3
[fetch]
	prune = true
[rebase]
	autostash = true
[diff]
	colorMoved = default
[difftool]
	prompt = false
[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"
[pager]
	difftool = false
[init]
	defaultBranch = main
[filter "dotfiles-path"]
	smudge = DOTFILES=$(git rev-parse --show-toplevel) && sed \"s|__DOTFILES__|$DOTFILES|g\"
	clean = DOTFILES=$(git rev-parse --show-toplevel) && sed \"s|$DOTFILES|__DOTFILES__|g\"
[include]
	path = config.local
