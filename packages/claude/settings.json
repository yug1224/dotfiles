      "Bash(pnpm outdated:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm store:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm why:*)",
      "Bash(read:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(timeout:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "mcp__chrome_devtools__list_*",
      "mcp__codegraph__*",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__figma__get_design_context",
      "mcp__figma__get_figjam",
      "mcp__figma__get_metadata",
      "mcp__figma__get_screenshot",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*",
      "mcp__github__actions_get",
      "mcp__github__actions_list",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-get-comments",
      "mcp__notion__notion-search",
      "mcp__storybook__get_story_urls",
      "mcp__github__*_read",
      "mcp__user-github__get_*",
      "mcp__user-github__list_*",
      "mcp__user-github__search_*",
      "mcp__user-github__actions_get",
      "mcp__user-github__actions_list",
      "mcp__user-github__*_read"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean --force:*)",
      "Bash(git branch -D:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh gist delete:*)",
      "Bash(gh run delete:*)",
      "Bash(gh repo archive:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-shell.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
