      "Bash(comm:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git --no-pager log:*)",
      "Bash(git --no-pager show:*)",
      "Bash(git diff:*)",
      "Bash(git diff-tree:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(kill:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(codegraph:*)",
      "Bash(node:*)",
      "Bash(openspec:*)",
      "Bash(paste:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm exec oxlint:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm list:*)",
